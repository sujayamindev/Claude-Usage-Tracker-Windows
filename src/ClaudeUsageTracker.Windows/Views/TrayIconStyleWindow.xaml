<ui:FluentWindow x:Class="ClaudeUsageTracker.Windows.Views.TrayIconStyleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Claude Usage Tracker — Appearance"
        Icon="/Assets/AppIcon.ico"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">
    <StackPanel>
        <ui:TitleBar Title="Claude Usage Tracker — Appearance"/>
        <StackPanel Margin="20,16,20,20">
            <TextBlock Text="Tray icon appearance" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- Icon Style -->
            <TextBlock Text="ICON STYLE" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,8"/>
            <RadioButton x:Name="StyleProgressRing" GroupName="IconStyle" Margin="0,0,0,8"
                         Checked="Style_Checked">
                <StackPanel>
                    <TextBlock Text="Progress Ring" FontWeight="SemiBold"/>
                    <TextBlock Text="Circular arc — default" Opacity="0.6" FontSize="12"/>
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="StyleProgressBar" GroupName="IconStyle" Margin="0,0,0,8"
                         Checked="Style_Checked">
                <StackPanel>
                    <TextBlock Text="Progress Bar" FontWeight="SemiBold"/>
                    <TextBlock Text="Horizontal fill bar" Opacity="0.6" FontSize="12"/>
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="StyleCompact" GroupName="IconStyle" Margin="0,0,0,0"
                         Checked="Style_Checked">
                <StackPanel>
                    <TextBlock Text="Compact" FontWeight="SemiBold"/>
                    <TextBlock Text="Minimalist status-color dot" Opacity="0.6" FontSize="12"/>
                </StackPanel>
            </RadioButton>

            <Separator Margin="0,16,0,16"/>

            <!-- Color Mode -->
            <TextBlock Text="COLOR MODE" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,8"/>
            <RadioButton x:Name="ColorMulti" GroupName="ColorMode" Margin="0,0,0,8"
                         Checked="Color_Checked">
                <StackPanel>
                    <TextBlock Text="Multi-Color" FontWeight="SemiBold"/>
                    <TextBlock Text="Green, orange, red based on usage level" Opacity="0.6" FontSize="12"/>
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="ColorMono" GroupName="ColorMode" Margin="0,0,0,8"
                         Checked="Color_Checked">
                <StackPanel>
                    <TextBlock Text="Greyscale" FontWeight="SemiBold"/>
                    <TextBlock Text="White — adapts to tray background" Opacity="0.6" FontSize="12"/>
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="ColorSingle" GroupName="ColorMode" Margin="0,0,0,8"
                         Checked="Color_Checked">
                <StackPanel>
                    <TextBlock Text="Single Color" FontWeight="SemiBold"/>
                    <TextBlock Text="Custom color of your choice" Opacity="0.6" FontSize="12"/>
                </StackPanel>
            </RadioButton>
            <StackPanel x:Name="SingleColorPickerHost" Visibility="Collapsed" Margin="0,4,0,0">
                <TextBlock Text="Custom color (hex):" FontSize="12" Opacity="0.7" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="ColorPreviewSwatch" Width="28" Height="28" CornerRadius="4"
                            Margin="0,0,10,0" BorderThickness="1" BorderBrush="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:TextBox x:Name="SingleColorHexBox" Width="130" PlaceholderText="#00BFFF"
                                TextChanged="SingleColorHex_TextChanged"/>
                </StackPanel>
            </StackPanel>

            <Separator Margin="0,16,0,16"/>

            <!-- Display -->
            <TextBlock Text="DISPLAY" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,8"/>
            <CheckBox x:Name="PaceMarkerCheck" Margin="0,0,0,8"
                      Click="PaceMarker_Click">
                <StackPanel>
                    <TextBlock Text="Pace marker" FontWeight="SemiBold"/>
                    <TextBlock Text="Time-elapsed tick colored by projected usage rate"
                               Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </CheckBox>
            <CheckBox x:Name="RemainingCheck" Margin="0,0,0,0"
                      Click="Remaining_Click">
                <StackPanel>
                    <TextBlock Text="Show remaining %" FontWeight="SemiBold"/>
                    <TextBlock Text="Remaining capacity instead of used (bar fill unchanged)"
                               Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </CheckBox>

            <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Margin="0,16,0,0"/>
            <ui:Button x:Name="CloseButton" Content="Close" HorizontalAlignment="Stretch"
                       Margin="0,12,0,0" Click="CloseButton_Click"/>
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
