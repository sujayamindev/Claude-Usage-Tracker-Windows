<ui:FluentWindow x:Class="ClaudeUsageTracker.Windows.Views.NotificationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Claude Usage Tracker — Notifications"
        Icon="/Assets/AppIcon.ico"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">
    <StackPanel>
        <ui:TitleBar Title="Claude Usage Tracker — Notifications"/>
        <StackPanel Margin="20">
            <TextBlock Text="Threshold notifications" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="Get a notification when your session or weekly usage crosses a percentage you choose."/>
            <ui:ToggleSwitch x:Name="NotificationsEnabledToggle" Content="Enable notifications" Margin="0,0,0,8"
                              Checked="NotificationsEnabledToggle_Toggled" Unchecked="NotificationsEnabledToggle_Toggled"/>
            <ui:ToggleSwitch x:Name="SoundEnabledToggle" Content="Play sound" Margin="0,0,0,16"
                              Checked="SoundEnabledToggle_Toggled" Unchecked="SoundEnabledToggle_Toggled"/>

            <TextBlock Text="Session thresholds" FontWeight="Bold" Margin="0,0,0,4"/>
            <StackPanel x:Name="SessionThresholdsPanel" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBox x:Name="SessionNewThresholdInput" Width="60" Margin="0,0,8,0"/>
                <ui:Button Content="Add" Click="AddSessionThreshold_Click"/>
            </StackPanel>

            <TextBlock Text="Weekly thresholds" FontWeight="Bold" Margin="0,0,0,4"/>
            <StackPanel x:Name="WeeklyThresholdsPanel" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBox x:Name="WeeklyNewThresholdInput" Width="60" Margin="0,0,8,0"/>
                <ui:Button Content="Add" Click="AddWeeklyThreshold_Click"/>
            </StackPanel>

            <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <ui:Button x:Name="CloseButton" Content="Close" HorizontalAlignment="Stretch" Click="CloseButton_Click"/>
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
