<Window x:Class="ClaudeUsageTracker.Windows.Views.PopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClaudeUsageTracker.Windows.Views"
        Title="Claude Usage Tracker"
        Width="300" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        Deactivated="PopoverWindow_Deactivated">
    <Window.Resources>
        <local:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
    </Window.Resources>
    <Border Background="White" CornerRadius="8" Padding="16" BorderBrush="#DDDDDD" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.25"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="Claude Usage" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>

            <TextBlock x:Name="StaleBanner" Text="Showing last known values — refresh failed"
                       Foreground="#B26A00" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed"/>

            <TextBlock Text="Session (5h window)" FontSize="12" Foreground="#666666"/>
            <Grid Margin="0,2,0,10">
                <ProgressBar x:Name="SessionBar" Height="8" Minimum="0" Maximum="100"
                             Foreground="{Binding SessionStatus, Converter={StaticResource StatusToBrushConverter}}"/>
            </Grid>
            <TextBlock x:Name="SessionPercentText" Text="0%" FontSize="13" Margin="0,-4,0,10"/>

            <TextBlock Text="Weekly" FontSize="12" Foreground="#666666"/>
            <Grid Margin="0,2,0,10">
                <ProgressBar x:Name="WeeklyBar" Height="8" Minimum="0" Maximum="100"
                             Foreground="{Binding WeeklyStatus, Converter={StaticResource StatusToBrushConverter}}"/>
            </Grid>
            <TextBlock x:Name="WeeklyPercentText" Text="0%" FontSize="13" Margin="0,-4,0,12"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="RefreshButton" Content="Refresh" Padding="10,4" Margin="0,0,8,0" Click="RefreshButton_Click"/>
                <Button x:Name="SignOutButton" Content="Sign Out" Padding="10,4" Click="SignOutButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
